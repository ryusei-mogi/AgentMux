# Copy to ~/.agentmux/accounts.env or .env and fill in your own keys.
# Do not commit the copied file.

# Local AgentMux API key. Generate one with:
#   openssl rand -hex 32
export AGENTMUX_API_KEY="replace-with-a-random-32-byte-local-token"

# First OpenCode Go subscription/account.
export OPENCODE_GO_A_KEY="sk-..."

# Optional additional OpenCode Go subscriptions/accounts.
# export OPENCODE_GO_B_KEY="sk-..."
# export OPENCODE_GO_C_KEY="sk-..."

# Multi-provider / multi-key examples.
# These are API keys and API account/project identifiers, not browser ChatGPT/Claude logins.
# export OPENAI_API_KEY_A="sk-..."
# export OPENAI_API_KEY_B="sk-..."
# export OPENAI_ORG_A="org_..."
# export OPENAI_ORG_B="org_..."
# export OPENAI_PROJECT_A="proj_..."
# export OPENAI_PROJECT_B="proj_..."
# export ANTHROPIC_API_KEY_A="sk-ant-..."
# export ANTHROPIC_API_KEY_B="sk-ant-..."
# export OPENROUTER_API_KEY="sk-or-..."
# export DEEPSEEK_API_KEY="sk-..."

# CLI backend examples use each CLI's own logged-in config directory.
# Log in before serving AgentMux, for example:
#   CODEX_HOME=~/.codex-main codex login
#   CLAUDE_CONFIG_DIR=~/.claude-main claude auth
