{
  "name": "@ryusei-mogi/agentmux",
  "version": "0.5.1",
  "description": "Quota-aware local OpenAI-compatible LLM gateway for coding agents.",
  "type": "module",
  "bin": {
    "agentmux": "dist/cli.js",
    "oc-router": "dist/cli.js"
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js serve",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.thresholds.branches=85 --coverage.thresholds.functions=85 --coverage.thresholds.lines=85 --coverage.thresholds.statements=85",
    "test:report": "vitest run --coverage --coverage.thresholds.branches=85 --coverage.thresholds.functions=85 --coverage.thresholds.lines=85 --coverage.thresholds.statements=85 --reporter=default --reporter=junit --outputFile.junit=test-results/vitest-junit.xml",
    "lint": "eslint .",
    "format": "prettier --check .",
    "check:oss-safety": "node scripts/check-oss-safety.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryusei-mogi/AgentMux.git"
  },
  "bugs": {
    "url": "https://github.com/ryusei-mogi/AgentMux/issues"
  },
  "homepage": "https://github.com/ryusei-mogi/AgentMux#readme",
  "keywords": [
    "agentmux",
    "llm",
    "openai",
    "router",
    "coding-agent",
    "quota",
    "gateway"
  ],
  "author": "Ryusei Mogi",
  "license": "MIT",
  "engines": {
    "node": ">=22.13"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.1",
    "better-sqlite3": "^12.9.0",
    "commander": "^14.0.3",
    "gpt-tokenizer": "^3.4.0",
    "hono": "^4.12.18",
    "pino": "^10.3.1",
    "yaml": "^2.8.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  }
}
